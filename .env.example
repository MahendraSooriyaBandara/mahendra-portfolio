# Copy this file to .env and fill in your own values.
# Never commit the real .env file to git.

# Port the server listens on
PORT=3000

# Admin credentials — CHANGE THESE before deploying anywhere public
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Secret used to sign JWT tokens — MUST be a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please_change_me_to_a_long_random_secret_string
